# syntax=docker/dockerfile:1
# ODay Plus web (Next.js, npm workspaces). Multi-stage: build then run the
# self-contained standalone server (next.config.mjs -> output: "standalone").
#
# NOTE: ODP_API_BASE_URL must be baked at build time. Next.js rewrite rules and 
# client-side references are resolved during the build stage. Providing ODP_API_BASE_URL 
# as a runtime environment variable will NOT have any effect on Next.js rewrites.
# If you need to customize ODP_API_BASE_URL, pass it as a build argument:
#   docker build --build-arg ODP_API_BASE_URL=https://api.yourdomain.com ...

FROM node:22-slim AS builder
WORKDIR /app

# Install workspace deps first (better layer caching). Root manifest + lockfile
# plus packages/ folder containing local workspace dependencies.
COPY package.json package-lock.json ./
COPY apps/web/package.json ./apps/web/package.json
COPY packages ./packages
RUN npm ci

# Copy the rest of the application code
COPY . .

# Build design tokens first (tokens:build)
RUN npm run tokens:build

# Build the web workspace
RUN npm run build --workspace=@oday-plus/web

FROM node:22-slim AS runner
WORKDIR /app
ENV NODE_ENV=production \
    PORT=8080 \
    HOSTNAME=0.0.0.0

# Standalone output carries its own minimal node_modules + server.js,
# laid out under the monorepo path apps/web/.
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

EXPOSE 8080
CMD ["node", "apps/web/server.js"]
