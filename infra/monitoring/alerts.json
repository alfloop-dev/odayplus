{
  "$schema": "https://oday.plus/schemas/monitoring/alerts.v1.json",
  "source_baseline": "ODP-SD-11 §9 (Alert Rules), ODP-SD-10 §11 (Incident 分級)",
  "description": "Cloud Monitoring alert policies. Each rule names the metric it watches (PLATFORM_METRICS), a severity, and the runbook that owns the response.",
  "alerts": [
    {
      "id": "api-availability-drop",
      "name": "API availability drop",
      "severity": "P1",
      "metric": "api_error_count",
      "condition": "5xx rate over rolling 5m exceeds SLO error budget burn, or api_latency_ms P95 > SLO",
      "secondary_metric": "api_latency_ms",
      "runbook": "docs/runbooks/observability-and-runbook.md#api-anomaly"
    },
    {
      "id": "forecast-daily-failed",
      "name": "Forecast daily batch failed",
      "severity": "P2",
      "metric": "job_failure_count",
      "condition": "forecast-batch-score job not succeeded before daily cutoff",
      "runbook": "docs/runbooks/observability-and-runbook.md#forecastops"
    },
    {
      "id": "data-quality-p0-fail",
      "name": "Data quality P0 fail",
      "severity": "P2",
      "metric": "data_quality_score",
      "condition": "P0 view data_quality_score below pass threshold",
      "runbook": "docs/runbooks/observability-and-runbook.md#data-freshness"
    },
    {
      "id": "dlq-spike",
      "name": "DLQ spike",
      "severity": "P2",
      "metric": "dlq_message_count",
      "condition": "critical topic dlq_message_count exceeds threshold",
      "runbook": "docs/runbooks/observability-and-runbook.md#job-failure"
    },
    {
      "id": "unauthorized-spike",
      "name": "Unauthorized spike",
      "severity": "P2",
      "metric": "api_error_count",
      "condition": "401/403 rate rises abnormally",
      "runbook": "docs/runbooks/observability-and-runbook.md#audit-write-failure"
    },
    {
      "id": "audit-write-failure",
      "name": "Audit write failure",
      "severity": "P1",
      "metric": "audit_event_write_failure_count",
      "condition": "any audit_event_write_failure_count for high-risk action or export in production",
      "secondary_metric": "audit_event_replay_count",
      "runbook": "docs/runbooks/observability-and-runbook.md#audit-write-failure"
    },
    {
      "id": "model-drift-high",
      "name": "Model drift high",
      "severity": "P2",
      "metric": "drift_score",
      "condition": "drift_score above model release policy threshold",
      "runbook": "docs/runbooks/observability-and-runbook.md#model-release"
    },
    {
      "id": "price-constraint-violation",
      "name": "Price hard-constraint violation",
      "severity": "P1",
      "metric": "price_hard_constraint_violation_count",
      "condition": "any executed plan violates a hard constraint",
      "runbook": "docs/runbooks/observability-and-runbook.md#priceops"
    },
    {
      "id": "data-room-abnormal-download",
      "name": "Data Room abnormal download",
      "severity": "P1",
      "metric": "audit_evidence_export_count",
      "condition": "high-volume or unauthorized export attempts in a short window",
      "runbook": "docs/runbooks/observability-and-runbook.md#audit-write-failure"
    },
    {
      "id": "solver-repeated-infeasible",
      "name": "Solver repeated infeasible",
      "severity": "P3",
      "metric": "job_failure_count",
      "condition": "same scenario returns infeasible consecutively",
      "runbook": "docs/runbooks/observability-and-runbook.md#netplan"
    },
    {
      "id": "external-connector-stale",
      "name": "External connector stale",
      "severity": "P3",
      "metric": "data_freshness_hours",
      "condition": "external source exceeds freshness SLA",
      "secondary_metric": "external_connector_failure_count",
      "runbook": "docs/runbooks/observability-and-runbook.md#data-freshness"
    }
  ]
}
