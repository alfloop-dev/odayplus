{
  "contract_id": "admin_boundary_snapshot",
  "title": "Administrative Boundary Snapshot",
  "kind": "external",
  "doc_ref": "ODP-DATA-03 §6 (CONN-GEO-ADMIN), §9.3; ODP-DATA-05 §6.4",
  "source_system": "SRC-EXT-ADMIN-BOUNDARY",
  "source_dataset": "admin_boundary_snapshot",
  "canonical_target": "geo_cell",
  "mapping_id": "MAP-EXT-ADMIN-BOUNDARY-v1",
  "integration_mode": "batch_snapshot",
  "envelope": "batch",
  "acquisition_method": "public_dataset",
  "schema_version": "admin-boundary-v1",
  "fields": [
    {"name": "source_boundary_id", "type": "string", "required": true, "description": "Source administrative boundary id."},
    {"name": "admin_level", "type": "string", "required": true, "enum": ["city", "district", "village"], "description": "Administrative level."},
    {"name": "admin_code", "type": "string", "required": true, "description": "Official administrative code."},
    {"name": "admin_name", "type": "string", "required": true, "description": "Administrative unit name."},
    {"name": "parent_admin_code", "type": "string", "required": false, "description": "Parent administrative code (district -> city)."},
    {"name": "centroid_latitude", "type": "number", "required": false, "minimum": -90, "description": "Representative-point latitude."},
    {"name": "centroid_longitude", "type": "number", "required": false, "minimum": -180, "description": "Representative-point longitude."},
    {"name": "area_km2", "type": "number", "required": false, "minimum": 0, "invalid_code": "invalid_amount", "description": "Boundary area in km^2."},
    {"name": "effective_date", "type": "date", "required": false, "description": "Boundary effective date."},
    {"name": "snapshot_id", "type": "string", "required": true, "description": "Source snapshot id for reproducibility."}
  ]
}
