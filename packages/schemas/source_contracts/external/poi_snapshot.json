{
  "contract_id": "poi_snapshot",
  "title": "POI Snapshot",
  "kind": "external",
  "doc_ref": "ODP-DATA-03 §6 (CONN-GEO-POI), §9.1; ODP-DATA-05 §6.1",
  "source_system": "SRC-EXT-POI",
  "source_dataset": "poi_snapshot",
  "canonical_target": "poi",
  "mapping_id": "MAP-EXT-POI-v1",
  "integration_mode": "batch_snapshot",
  "envelope": "batch",
  "acquisition_method": "api",
  "fields": [
    {"name": "source_poi_id", "type": "string", "required": true, "description": "Provider POI id."},
    {"name": "poi_name", "type": "string", "required": true, "description": "POI name."},
    {"name": "poi_category", "type": "string", "required": true, "description": "POI category (taxonomy mapped)."},
    {"name": "poi_subcategory", "type": "string", "required": false, "description": "POI subcategory."},
    {"name": "address_raw", "type": "string", "required": false, "description": "Raw address."},
    {"name": "latitude", "type": "number", "required": false, "minimum": -90, "description": "Latitude."},
    {"name": "longitude", "type": "number", "required": false, "minimum": -180, "description": "Longitude."},
    {"name": "status", "type": "string", "required": true, "enum": ["active", "closed", "unknown"], "description": "POI status."},
    {"name": "confidence", "type": "number", "required": false, "minimum": 0, "description": "Provider + geocode confidence (0-1)."},
    {"name": "snapshot_id", "type": "string", "required": true, "description": "Source snapshot id for reproducibility."}
  ]
}
