{
  "contract_id": "listing_raw_snapshot",
  "title": "Listing Raw Snapshot",
  "kind": "external",
  "doc_ref": "ODP-DATA-03 §6 (CONN-LISTING-PARTNER), §8; ODP-DATA-05 §6.3",
  "source_system": "SRC-EXT-LISTING-PARTNER",
  "source_dataset": "listing_raw_snapshot",
  "canonical_target": "listing",
  "mapping_id": "MAP-EXT-LISTING-v1",
  "integration_mode": "batch_snapshot",
  "envelope": "batch",
  "acquisition_method": "feed",
  "fields": [
    {"name": "source_listing_id", "type": "string", "required": true, "description": "Source listing id; hash natural key if absent."},
    {"name": "address_raw", "type": "string", "required": true, "description": "Raw address."},
    {"name": "rent_amount", "type": "number", "required": true, "minimum": 0, "invalid_code": "invalid_amount", "description": "Rent amount; must be > 0 if actively listed."},
    {"name": "currency", "type": "string", "required": false, "description": "Currency code."},
    {"name": "area_ping", "type": "number", "required": false, "minimum": 0, "invalid_code": "invalid_amount", "description": "Area in ping."},
    {"name": "floor", "type": "string", "required": false, "description": "Floor (basement/1F/2F...)."},
    {"name": "available_from", "type": "date", "required": false, "description": "Available-from date."},
    {"name": "listing_status", "type": "string", "required": true, "enum": ["active", "inactive", "leased", "manual_review", "stale"], "description": "Listing status."},
    {"name": "confidence", "type": "number", "required": false, "minimum": 0, "description": "Extraction / geocode confidence (0-1)."},
    {"name": "snapshot_id", "type": "string", "required": true, "description": "Source snapshot id for reproducibility."}
  ]
}
