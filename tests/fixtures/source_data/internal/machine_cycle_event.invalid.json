      },
      "expect_codes": ["invalid_time"]
    },
    {
      "label": "unmapped cycle_type enum",
      "record": {
        "source_cycle_id": "CY-9003",
        "source_store_id": "S001",
        "source_machine_id": "M-ABC123",
        "cycle_start_time": "2026-06-26T08:10:00+08:00",
        "cycle_type": "spin",
