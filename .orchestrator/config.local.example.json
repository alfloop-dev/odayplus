{
  // Local-only overrides for this machine.
  // Copy to `.orchestrator/config.local.json` if you want a fresh personal override file.
  "supervisor": {
    // Refresh provider capabilities on each supervisor loop so dashboard state updates
    // after local auth or IAM changes.
    "auto_refresh_provider_capabilities": true
  },
  "coordination": {
    "repositories": {
      "front_ai_trading_system": {
        // Override this if your front-end checkout lives somewhere else.
        "local_path": "../front-ai-trading-system"
      }
    },
    "lovable": {
      // Export this env var locally so generated Lovable task packets include a one-click project URL.
      "project_url_env": "PANTHEON_FRONT_LOVABLE_PROJECT_URL",
      "project_url": "https://lovable.dev/projects/your-project-id"
    }
  }
}
