{
  "paths": {
    "status_file": "ai-status.json",
    "activity_log": "ai-activity-log.jsonl",
    "current_work": "current-work.md",
    "dashboard": "docs-site/index.html",
    "state_file": ".orchestrator/state.json",
    "event_queue": ".orchestrator/event-queue.jsonl",
    "approval_queue": ".orchestrator/approval-queue.json",
    "sidecar_catalog": ".orchestrator/sidecar_catalog.json",
    "github_bus_state": ".orchestrator/github-bus-state.json",
    "github_webhook_events": ".orchestrator/github-webhook-events.jsonl",
    "github_relay_state": ".orchestrator/github-relay-state.json",
    "provider_capabilities": ".orchestrator/provider_capabilities.json",
    "claude_mcp_config": ".orchestrator/claude-approval-broker.mcp.json"
  },
  "permission_broker": {
    "allowed_workspace_roots": [
      ".",
      "../execute-plans"
    ]
  },
  "watcher": {
    "poll_interval_seconds": 2.0,
    "replay_on_start": false,
    "max_seen_events": 2000
  },
  "supervisor": {
    "poll_interval_seconds": 300.0,
    "heartbeat_warn_after_seconds": 10.0,
    "stall_after_seconds": 300,
    "max_worker_history": 200,
    "auto_refresh_provider_capabilities": true
  },
  "worker_runtime": {
    "worker_lease_seconds": 1800,
    "queue_lease_seconds": 1800,
    "heartbeat_stale_seconds": 300,
    "heartbeat_grace_seconds": 60,
    "runner_heartbeat_interval_seconds": 15
  },
  "watchdog": {
    "enabled": true,
    "state_file": ".orchestrator/watchdog-state.json",
    "metrics_file": ".orchestrator/metrics/supervisor-watchdog.jsonl",
    "heartbeat_stale_seconds": 900,
    "restart_budget_window_seconds": 900,
    "max_restarts_per_window": 2,
    "max_restarts_per_hour": 4,
    "backoff_schedule_seconds": [
      30,
      120,
      300,
      900
    ],
    "circuit_cooldown_seconds": 1800,
    "safe_mode_seconds": 120,
    "min_disk_free_gb": 2.0,
    "max_disk_used_percent": 95.0,
    "min_memory_available_mb": 512,
    "max_load_1m": 24.0,
    "max_active_workers": 12,
    "supervisor_command": [
      "python3",
      "-u",
      ".orchestrator/supervisor.py",
      "--verbose"
    ]
  },
  "provider_guardrails": {
    "pause_on_capacity_failure": true,
    "pause_on_auth_failure": true,
    "capacity_pause_seconds": 900,
    "auth_pause_seconds": 900
  },
  "worker_tree_guard": {
    "enabled": false,
    "mode": "warn",
    "blocking_globs": [
      ".orchestrator/supervisor.py",
      "supervisor.py",
      ".orchestrator/skills/**",
      "branch-strategy.md",
      "docs/conventions/GIT_WORKFLOW.md",
      "config*.json",
      ".orchestrator/config*.json",
      "docs/**"
    ],
    "auto_restore_globs": [
      "ai-activity-log.jsonl",
      "ai-status.json",
      "current-work.md",
      "dashboard-bundle.json",
      "docs-site/**"
    ],
    "auto_restore_enabled": false
  },
  "worker_worktrees": {
    "enabled": true,
    "root": "/tmp/pantheon-worker-worktrees",
    "base_ref": "origin/main",
    "reuse_existing": true,
    "execution_reasons": [
      "owned_ready_dispatch",
      "owned_in_progress_dispatch",
      "owned_finalize_dispatch",
      "review_ready_dispatch",
      "chair_review:*"
    ]
  },
  "worker_retry": {
    "enabled": true,
    "max_attempts": 5,
    "backoff_schedule_seconds": [
      5,
      15,
      30,
      60,
      120
    ],
    "jitter_seconds": 3,
    "transient_error_patterns": [
      "429",
      "resource_exhausted",
      "rate limit",
      "rate limited",
      "timed out",
      "etimedout",
      "econnreset",
      "temporarily unavailable",
      "try again later",
      "server overloaded",
      "deadline exceeded",
      "terminalquotaerror",
      "retryablequotaerror",
      "quota_exhausted",
      "quota exhausted",
      "exhausted your capacity",
      "no capacity available for model"
    ],
    "fallback_mode": "file_inbox"
  },
  "worker_reassignment": {
    "enabled": true,
    "after_attempts": 2,
    "reassign_on_terminal_failure": true,
    "eligible_statuses": [
      "todo",
      "in_progress",
      "review",
      "review_approved"
    ],
    "owner_fallbacks": {
      "Claude": [
        "Claude2",
        "Codex",
        "Codex2",
        "Antigravity",
        "Antigravity2"
      ],
      "Claude2": [
        "Claude",
        "Codex",
        "Codex2",
        "Antigravity",
        "Antigravity2"
      ],
      "Antigravity": [
        "Antigravity2",
        "Codex",
        "Codex2",
        "Claude",
        "Claude2"
      ],
      "Antigravity2": [
        "Antigravity",
        "Codex",
        "Codex2",
        "Claude",
        "Claude2"
      ],
      "Codex": [
        "Codex2",
        "Claude",
        "Claude2",
        "Antigravity",
        "Antigravity2"
      ],
      "Codex2": [
        "Codex",
        "Claude",
        "Claude2",
        "Antigravity",
        "Antigravity2"
      ]
    },
    "reviewer_fallbacks": {
      "Claude": [
        "Claude2",
        "Codex",
        "Codex2",
        "Antigravity",
        "Antigravity2"
      ],
      "Claude2": [
        "Claude",
        "Codex",
        "Codex2",
        "Antigravity",
        "Antigravity2"
      ],
      "Antigravity": [
        "Antigravity2",
        "Codex",
        "Codex2",
        "Claude",
        "Claude2"
      ],
      "Antigravity2": [
        "Antigravity",
        "Codex",
        "Codex2",
        "Claude",
        "Claude2"
      ],
      "Codex": [
        "Codex2",
        "Claude",
        "Claude2",
        "Antigravity",
        "Antigravity2"
      ],
      "Codex2": [
        "Codex",
        "Claude",
        "Claude2",
        "Antigravity",
        "Antigravity2"
      ]
    }
  },
  "underutilization_dispatch": {
    "enabled": false,
    "threshold_ratio": 0.5,
    "continuous_window_seconds": 900,
    "cooldown_seconds": 900,
    "max_new_sidecars_per_wave": 2,
    "max_active_sidecars_per_agent": 1,
    "productive_worker_statuses": [
      "running",
      "waiting_approval",
      "suspended_approval",
      "retry_backoff"
    ]
  },
  "approvals": {
    "stale_pending_seconds": 1800
  },
  "coordination": {
    "enabled": true,
    "repositories": {
      "pantheon": {
        "repo": null,
        "local_path": ".",
        "default_branch": "main"
      },
      "front_ai_trading_system": {
        "repo": "your-org/front-ai-trading-system",
        "local_path": "../front-ai-trading-system",
        "default_branch": "main"
      },
      "runtime_platform": {
        "repo": "your-org/lean-platform",
        "local_path": "../lean-platform",
        "default_branch": "main"
      },
      "lean_engine": {
        "repo": "your-org/pantheon-lean",
        "local_path": "../Lean",
        "default_branch": "master"
      }
    },
    "worker_routes": {
      "pantheon-bff-worker": {
        "target_agent": "Codex"
      },
      "front-sync-worker": {
        "target_agent": "Codex"
      },
      "front-ui-worker": {
        "target_agent": "Antigravity"
      },
      "runtime-worker": {
        "target_agent": "Antigravity"
      },
      "engine-worker": {
        "target_agent": "Claude",
        "requires_human_approval": true
      },
      "qa-worker": {
        "target_agent": "Claude"
      }
    },
    "lovable": {
      "project_url_env": "PANTHEON_FRONT_LOVABLE_PROJECT_URL",
      "project_url": "https://lovable.dev/projects/your-project-id"
    }
  },
  "github_bus": {
    "enabled": true,
    "command_timeout_seconds": 8,
    "poll_interval_seconds": 30,
    "repo": null,
    "default_branch": "main",
    "offline_backoff_seconds": 300,
    "auto_request_reviewers": true,
    "close_resolved_issues": true,
    "labels": {
      "review": [
        "pantheon-bus",
        "pantheon-review"
      ],
      "ops": [
        "pantheon-bus",
        "pantheon-ops",
        "approval-needed"
      ],
      "coordination": [
        "pantheon-bus",
        "coordination-bus"
      ],
      "resolved": [
        "resolved"
      ]
    },
    "commands": [
      "/approve",
      "/deny",
      "/retry",
      "/resume",
      "/recheck",
      "/status",
      "/dispatch",
      "/needs-runtime",
      "/contract-ready",
      "/approve-engine"
    ],
    "reviewers": {
      "Claude": [
        "Alien-alfaloop"
      ],
      "Antigravity": [
        "ajoe734"
      ],
      "Codex": [
        "Alien-alfaloop"
      ]
    },

    "templates": {
      "ops_issue": ".orchestrator/templates/github_ops_issue.md",
      "review_pr": ".orchestrator/templates/github_review_pr.md"
    },
    "phase3": {
      "github_app": {
        "enabled": false,
        "app_id_env": "PANTHEON_GITHUB_APP_ID",
        "private_key_env": "PANTHEON_GITHUB_APP_PRIVATE_KEY",
        "installation_id_env": "PANTHEON_GITHUB_INSTALLATION_ID"
      },
      "webhook": {
        "enabled": false,
        "host": "127.0.0.1",
        "port": 8776,
        "secret_env": "PANTHEON_GITHUB_WEBHOOK_SECRET"
      },
      "cloud_relay": {
        "enabled": false,
        "url_env": "PANTHEON_GITHUB_RELAY_URL",
        "token_env": "PANTHEON_GITHUB_RELAY_TOKEN"
      }
    }
  },
  "schema": {
    "tasks_path": "tasks",
    "handoffs_path": "handoffs",
    "task_id_field": "id",
    "status_field": "status",
    "assignee_field": "owner",
    "reviewer_field": "reviewer",
    "artifacts_field": "artifacts",
    "next_field": "next",
    "last_update_field": "last_update"
  },
  "events": {
    "enqueue_runtime_events": false,
    "review_statuses": [
      "review"
    ],
    "status_targets": {
      "needs_reply": "owner",
      "needs_input": "owner",
      "handoff": "owner"
    },
    "waiting_status_patterns": [
      "^waiting_on_(?P<agent>[A-Za-z0-9_-]+)$"
    ],
    "watch_assignee_changes": false,
    "watch_reviewer_changes": false,
    "watch_handoffs": false,
    "pending_handoff_statuses": [
      "pending"
    ]
  },
  "agents": {
    "claude": {
      "display_name": "Claude",
      "provider": "claude",
      "adapter": "claude_cli",
      "wake_template": ".orchestrator/templates/wakeup.txt",
      "file_inbox_path": ".llm-inbox/claude.md"
    },
    "claude2": {
      "display_name": "Claude2",
      "provider": "claude",
      "adapter": "claude_cli",
      "wake_template": ".orchestrator/templates/wakeup.txt",
      "file_inbox_path": ".llm-inbox/claude2.md"
    },
    "antigravity": {
      "display_name": "Antigravity",
      "provider": "antigravity",
      "adapter": "antigravity",
      "wake_template": ".orchestrator/templates/wakeup.txt",
      "file_inbox_path": ".llm-inbox/antigravity.md"
    },
    "antigravity2": {
      "display_name": "Antigravity2",
      "provider": "antigravity2",
      "adapter": "antigravity",
      "wake_template": ".orchestrator/templates/wakeup.txt",
      "file_inbox_path": ".llm-inbox/antigravity2.md"
    },
    "codex": {
      "display_name": "Codex",
      "provider": "codex",
      "adapter": "codex",
      "wake_template": ".orchestrator/templates/wakeup.txt",
      "file_inbox_path": ".llm-inbox/codex.md"
    },
    "codex2": {
      "display_name": "Codex2",
      "provider": "codex",
      "adapter": "codex",
      "wake_template": ".orchestrator/templates/wakeup.txt",
      "file_inbox_path": ".llm-inbox/codex2.md"
    }
  },
  "providers": {
    "claude": {
      "delivery_mode": "claude_cli",
      "file_inbox": {
        "path": ".llm-inbox/claude.md",
        "open_in_vscode": false
      },
      "runtime": {
        "cli": ".orchestrator/bin/claude",
        "output_format": "stream-json",
        "include_hook_events": true,
        "permission_mode": "acceptEdits",
        "resume_permission_mode_after_approval": "acceptEdits",
        "resume_use_allowed_tools_from_approval": true,
        "enable_auto_mode_if_supported": true,
        "auto_permission_mode": "auto",
        "mcp_config": ".orchestrator/claude-approval-broker.mcp.json",
        "permission_prompt_tool": "mcp__orchestrator_approval_broker__approval_prompt"
      },
      "broker": {
        "approval_wait_seconds": 3600,
        "http_host": "127.0.0.1",
        "http_port": 8765,
        "persist_allow_by_default": false
      },
      "approval": {
        "workspace_permission_mode": "acceptEdits",
        "allow_dangerous_skip": false,
        "copilot_allow_dangerous_skip": false,
        "rule_default_mode": "acceptEdits",
        "disable_bypass_permissions": true
      }
    },
    "antigravity": {
      "delivery_mode": "antigravity",
      "allow_inbox_fallback": true,
      "file_inbox": {
        "path": ".llm-inbox/antigravity.md",
        "open_in_vscode": false
      },
      "antigravity": {
        "cli": ".orchestrator/bin/agy",
        "include_directories": true,
        "env": {
          "GEMINI_CLI_TRUST_WORKSPACE": "true",
          "GOOGLE_GENAI_USE_GCA": "true"
        }
      },
      "approval": {
        "dangerously_skip_permissions": true
      }
    },
    "antigravity2": {
      "delivery_mode": "antigravity",
      "allow_inbox_fallback": true,
      "file_inbox": {
        "path": ".llm-inbox/antigravity2.md",
        "open_in_vscode": false
      },
      "antigravity": {
        "cli": ".orchestrator/bin/agy",
        "config_home": "~/.gemini-ag2",
        "home": "~/.gemini-ag2",
        "include_directories": true,
        "env": {
          "GEMINI_CLI_TRUST_WORKSPACE": "true",
          "GOOGLE_GENAI_USE_GCA": "true"
        }
      },
      "approval": {
        "dangerously_skip_permissions": true
      }
    },
    "codex": {
      "delivery_mode": "codex",
      "file_inbox": {
        "path": ".llm-inbox/codex.md",
        "open_in_vscode": false
      },
      "codex": {
        "cli": "codex",
        "ask_for_approval": "never",
        "sandbox_mode": "workspace-write",
        "dangerously_bypass": true
      },
      "approval": {
        "orchestrator_only": true,
        "ask_for_approval": "never",
        "sandbox_mode": "workspace-write",
        "dangerously_bypass": true
      }
    }
  },
  "ready_dispatcher": {
    "enabled": true,
    "review_statuses": [
      "review"
    ],
    "finalize_statuses": [
      "review_approved"
    ],
    "owned_statuses": [
      "in_progress",
      "todo"
    ],
    "disabled_agents": [],
    "dependency_done_statuses": [
      "done"
    ],
    "worker_terminal_statuses": [
      "review",
      "done",
      "review_approved"
    ],
    "active_worker_statuses": [
      "running",
      "waiting_approval",
      "suspended_approval",
      "retry_backoff",
      "manual_pending",
      "stalled"
    ],
    "helper_claim": {
      "enabled": true,
      "task_statuses": [
        "todo"
      ],
      "require_owner_higher_priority_load": true
    },
    "worker_self_claim": {
      "enabled": true,
      "claim_command": "AI_NAME=$AI_NAME python3 .orchestrator/supervisor.py --claim-agent \"$AI_NAME\" --release-task \"$TASK_ID\" --quiet",
      "release_task_statuses": [
        "review",
        "review_approved",
        "done",
        "blocked"
      ]
    },
    "max_tasks_per_agent_by_agent": {
      "Claude": 3,
      "Claude2": 3,
      "Antigravity": 2,
      "Antigravity2": 2,
      "Codex": 4,
      "Codex2": 4
    },
    "max_dispatches_per_tick": 3,
    "max_active_workers_per_task": 1,
    "max_concurrent_per_quota_group": {
      "claude": 4,
      "antigravity": 2,
      "antigravity2": 2,
      "codex": 6
    },
    "max_concurrent_workers": 6
  },
  "branch_workflow": {
    "enabled": true,
    "task_branch_prefix": "task/",
    "publish_branch_prefix": "publish/",
    "release_tag_prefix": "release/",
    "prod_tag_prefix": "prod/",
    "archive_tag_prefix": "archive/",
    "dev_branch": "dev",
    "main_branch": "main",
    "nightly_publish": {
      "enabled": true,
      "cron_utc": "0 3 * * *",
      "version_format": "vYYYY.MM.DD.N",
      "skip_if_no_new_commits": true
    },
    "environments": {
      "dev": {
        "branch": "dev",
        "auto_deploy": true,
        "deploy_trigger": "on_push",
        "url_env": "ODP_DEV_DEPLOY_URL"
      },
      "staging": {
        "branch": "main",
        "auto_deploy": true,
        "deploy_trigger": "on_push",
        "url_env": "ODP_STAGING_DEPLOY_URL"
      }
    },
    "promote": {
      "source_branch": "dev",
      "target_branch": "main",
      "trigger": "ci_green",
      "require_dev_ci_green": true,
      "soak_days": 0,
      "regression_label_prefix": "regression/",
      "block_labels": [
        "hold-promote",
        "regression"
      ],
      "promote_pr_label": "auto-promote",
      "auto_merge": true,
      "auto_revert_on_red_main_ci": true
    },
    "task_pr": {
      "target_branch": "dev",
      "auto_merge": true,
      "required_status_checks": [
        "CI / test"
      ],
      "max_open_hours": 24
    },
    "drift_alarms": {
      "task_pr_must_merge_within_minutes": 120,
      "publish_must_promote_within_minutes": 30,
      "dev_must_not_diverge_from_main_more_than_minutes": 60
    },
    "orchestrator_sync_webhook": {
      "enabled": false,
      "url_env": "PANTHEON_ORCHESTRATOR_SYNC_URL",
      "secret_env": "PANTHEON_ORCHESTRATOR_SYNC_SECRET"
    }
  }
}
