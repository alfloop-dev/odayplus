#!/usr/bin/env bash
set -euo pipefail

gh_bin=""
shopt -s nullglob
candidates=("$HOME"/.local/share/pantheon-orchestrator-tools/gh-*/bin/gh)
shopt -u nullglob

if [[ ${#candidates[@]} -gt 0 ]]; then
  gh_bin="${candidates[${#candidates[@]}-1]}"
fi

if [[ -z "${gh_bin}" ]]; then
  # Exclude paths containing '.orchestrator/bin' to avoid calling ourselves recursively
  CLEAN_PATH="$(echo "$PATH" | tr ':' '\n' | grep -v '\.orchestrator/bin' | tr '\n' ':' | sed 's/:$//')"
  gh_bin="$(PATH="$CLEAN_PATH" command -v gh || true)"
  if [[ -z "${gh_bin}" ]]; then
    echo "GitHub CLI binary not found under ~/.local/share/pantheon-orchestrator-tools or in PATH." >&2
    exit 1
  fi
fi

exec "${gh_bin}" "$@"
