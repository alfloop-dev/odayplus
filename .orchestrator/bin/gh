#!/usr/bin/env bash
set -euo pipefail

gh_bin="$(ls -d "$HOME"/.local/share/pantheon-orchestrator-tools/gh-*/bin/gh 2>/dev/null | sort -V | tail -n1)"
if [[ -z "${gh_bin}" ]]; then
  echo "GitHub CLI binary not found under ~/.local/share/pantheon-orchestrator-tools." >&2
  exit 1
fi

exec "${gh_bin}" "$@"
