# Product E2E defaults. Copy or source this file for local overrides.
ODP_E2E_PROJECT=oday-plus-e2e
ODP_E2E_WEB_PORT=3100
ODP_E2E_API_PORT=8099
ODP_E2E_SOURCE_STUB_PORT=8077
ODP_E2E_DB_PATH=.odp_data/product-e2e.sqlite3
ODP_E2E_DIAGNOSTICS_DIR=.odp_data/e2e-diagnostics

# Runtime wiring used by the web server and Playwright.
ODP_API_BASE_URL=http://127.0.0.1:8099
NEXT_PUBLIC_API_URL=http://127.0.0.1:8099
ODP_PLAYWRIGHT_REUSE_EXISTING=1
